#!/usr/bin/env bash
# SessionStart hook for observational-memory plugin
# Reads behavioral profile files and injects them as context

set -euo pipefail

OM_DIR="${HOME}/.observational-memory"
MEMORY_DIR="${OM_DIR}/memory"

# If not installed, try auto-install (pip + init)
if [ ! -f "${OM_DIR}/memory.db" ]; then
  # Find the best python3 — prefer Homebrew (versioned) over system
  _om_python=""
  for _p in /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3.12 /opt/homebrew/bin/python3 /usr/local/bin/python3 python3; do
    if command -v "$_p" &>/dev/null; then _om_python="$_p"; break; fi
  done

  # Install pip package if not importable
  if [ -n "$_om_python" ] && ! "$_om_python" -c "import observational_memory" &>/dev/null; then
    "$_om_python" -m pip install --break-system-packages git+https://github.com/jgatt493/jg-observational-memory.git &>/dev/null \
      || "$_om_python" -m pip install --user git+https://github.com/jgatt493/jg-observational-memory.git &>/dev/null \
      || true
  fi

  # Run install via python -m (avoids PATH/binary issues)
  if [ -n "$_om_python" ] && "$_om_python" -c "import observational_memory" &>/dev/null; then
    "$_om_python" -m observational_memory install --no-key-check &>/dev/null || true
  fi

  # If still no DB after install attempt, inject setup instructions for the agent
  if [ ! -f "${OM_DIR}/memory.db" ]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
    setup_content=$(cat "${PLUGIN_ROOT}/skills/context.md" 2>/dev/null || echo "Observational memory plugin installed but skill file not found.")

    escape_for_json() {
      local s="$1"
      s="${s//\\/\\\\}"
      s="${s//\"/\\\"}"
      s="${s//$'\n'/\\n}"
      s="${s//$'\r'/\\r}"
      s="${s//$'\t'/\\t}"
      printf '%s' "$s"
    }

    escaped=$(escape_for_json "$setup_content")
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
    exit 0
  fi
fi

# Derive project slug from cwd: basename, lowercase, non-alnum to dash, strip leading/trailing dashes
slug=$(basename "${PWD}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/^-*//; s/-*$//')

# Collect context
context=""
loaded=""

# Global core
if [ -f "${MEMORY_DIR}/global.md" ]; then
  content=$(cat "${MEMORY_DIR}/global.md")
  chars=${#content}
  context="${context}\n\n## Global Behavioral Rules (apply as firm instructions)\n\n${content}"
  loaded="global (${chars} chars)"
fi

# Global context
if [ -f "${MEMORY_DIR}/global_context.md" ]; then
  content=$(cat "${MEMORY_DIR}/global_context.md")
  context="${context}\n\n## Global Context (informational background)\n\n${content}"
fi

# Project core
if [ -f "${MEMORY_DIR}/projects/${slug}.md" ]; then
  content=$(cat "${MEMORY_DIR}/projects/${slug}.md")
  chars=${#content}
  context="${context}\n\n## Project Rules: ${slug} (apply as firm instructions, override global if conflicting)\n\n${content}"
  loaded="${loaded:+${loaded}, }${slug} (${chars} chars)"
fi

# Project context
if [ -f "${MEMORY_DIR}/projects/${slug}_context.md" ]; then
  content=$(cat "${MEMORY_DIR}/projects/${slug}_context.md")
  context="${context}\n\n## Project Context: ${slug} (informational background)\n\n${content}"
fi

# Build output
if [ -n "$context" ]; then
  summary="Observational memory loaded: ${loaded}"
  full_context="<observational-memory>\n${summary}\n${context}\n</observational-memory>"
else
  full_context="<observational-memory>\nObservational memory: no profiles generated yet. They will appear after a few sessions.\n</observational-memory>"
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped=$(escape_for_json "$full_context")
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
exit 0
